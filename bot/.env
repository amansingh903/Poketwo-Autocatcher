# Required
DISCORD_TOKEN="Your_discord_token_here"
GUILD_ID=

# Optional IDs
OWNER_ID=
CATCH_CHANNEL_ID=
SPAM_CHANNEL_ID=

# Feature toggles
CATCH_ENABLED=true
SPAM_ENABLED=true
START_SLEEPING=false

# Catch behavior
AI_CONFIDENCE_THRESHOLD=90
CATCH_COOLDOWN_SECONDS=1.2
HINT_COOLDOWN_SECONDS=1.0

# Runtime state
STATE_FILE_PATH=bot/runtime_state.json
